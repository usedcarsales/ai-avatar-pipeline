# AI Avatar Pipeline — Environment Variables
# Copy this file to .env and fill in your API keys.

# Required: HeyGen API key (Creator plan, $29/mo)
# Get your key at https://app.heygen.com/avatar?nav=API
HEYGEN_API_KEY=your_heygen_api_key_here

# Optional: Fish Audio API key (only needed for custom voice mode)
# Get your key at https://fish.audio/
FISH_API_KEY=your_fish_audio_api_key_here

# Optional: Anthropic API key (for script generation, Phase 3)
ANTHROPIC_API_KEY=your_anthropic_key_here

# HeyGen defaults (get IDs from: python -m examples.list_available_avatars)
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=

# Fish Audio defaults
FISH_MODEL=s2
FISH_REFERENCE_ID=

# Video output settings
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
OUTPUT_DIR=output

# Polling settings (seconds)
POLL_INTERVAL=5.0
MAX_POLL_TIME=600.0

# Retry settings
MAX_RETRIES=3
BACKOFF_BASE=2.0

# YouTube Distribution (Phase 3)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
