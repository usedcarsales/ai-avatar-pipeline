# .env.example — AI Avatar Video Pipeline v2

# HeyGen CLI (required)
# Get your key at https://app.heygen.com/settings/api
# Set it via: heygen auth login   OR   export HEYGEN_API_KEY=...
HEYGEN_API_KEY=your_heygen_key_here

# Anthropic (for script generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Fish Audio (optional — for custom voice cloning)
# Only needed if you want to clone a specific voice not available in HeyGen
FISH_AUDIO_API_KEY=

# Pipeline Config
DEFAULT_AVATAR_ID=
DEFAULT_VOICE_ID=
OUTPUT_DIR=./output

# HeyGen CLI path (default: 'heygen' — change if installed elsewhere)
HEYGEN_BIN=heygen

# YouTube Distribution (Phase 3+)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=