{
  "name": "ai-avatar-pipeline",
  "version": "2.0.0",
  "description": "Automated AI avatar video production pipeline using HeyGen CLI + Claude",
  "type": "module",
  "main": "src/orchestrator.js",
  "scripts": {
    "start": "node src/orchestrator.js",
    "test": "node src/test/manualTest.js",
    "generate": "node src/orchestrator.js",
    "avatars": "node src/orchestrator.js --list-avatars",
    "batch": "node src/orchestrator.js --batch"
  },
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "heygen": {
    "cli": ">=0.0.4",
    "install": "curl -fsSL https://static.heygen.ai/cli/install.sh | bash"
  }
}